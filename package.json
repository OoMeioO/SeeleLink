{
  "name": "seelelink",
  "version": "0.1.0",
  "description": "Unified connector tool - SSH, Serial, PowerShell, WebSocket, MCP",
  "author": "SeeleLink Team",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/copy-assets.js",
    "electron:dev": "npm run build && node electron/start.cjs",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "start": "node dist/cli/index.js",
    "postinstall": "node scripts/patch-node-pty.cjs",
    "test": "node tests/run-all.cjs",
    "test:ui": "node tests/ui-smoke.cjs",
    "test:control": "node tests/control-api-tcp.cjs",
    "test:mcp": "node tests/mcp-api-http.cjs",
    "test:coverage": "node tests/integration/feature-coverage.test.cjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:all": "npm run test:unit && node tests/integration/feature-coverage.test.cjs"
  },
  "build": {
    "appId": "com.seelelink.app",
    "productName": "SeeleLink",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "SEELINK_CONTROL.md"
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": ["AppImage", "dir"],
      "category": "Network"
    },
    "mac": {
      "target": ["dmg", "dir"],
      "category": "public.app-category.network"
    },
    "asar": true,
    "npmRebuild": true
  },
  "dependencies": {
    "3": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@serialport/stream": "^12.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^12.0.0",
    "iconv-lite": "^0.7.2",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.1.0",
    "serialport": "^13.0.0",
    "ssh2": "^1.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.11.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.59.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
