{
  "name": "seelelink",
  "version": "0.1.0",
  "description": "Unified connector tool - SSH, Serial, PowerShell, WebSocket, MCP",
  "author": "SeeleLink Team",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --outDir dist",
    "electron:dev": "npm run build && electron .",
    "package": "npm run build && electron-builder --win --config.asar=false",
    "start": "node dist/cli/index.js"
  },
  "build": {
    "appId": "com.seelelink.app",
    "productName": "SeeleLink",
    "directories": {
      "output": "E:\\SeeleLink\\release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "asar": false,
    "npmRebuild": false
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@serialport/stream": "^12.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^12.0.0",
    "node-pty": "^1.1.0",
    "serialport": "^13.0.0",
    "ssh2": "^1.15.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.11.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
